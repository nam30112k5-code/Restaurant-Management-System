<Window x:Class="UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:helpers="clr-namespace:Helpers;assembly=RestaurantManagement.Helpers"
        xmlns:local="clr-namespace:UI"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:ViewModels;assembly=RestaurantManagement.ViewModels"
        mc:Ignorable="d"
        Title="Restaurant Management"
        Height="760"
        MinHeight="680"
        Width="1240"
        MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:LoginTextConverter x:Key="LoginTextConverter" />
        <local:MatchVisibilityConverter x:Key="SectionVisibilityConverter" />

        <DataTemplate DataType="{x:Type viewModels:LoginViewModel}">
            <Grid Background="{StaticResource PageBackgroundBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <Border Margin="24"
                        CornerRadius="8"
                        ClipToBounds="True">
                    <Border.Background>
                        <ImageBrush ImageSource="Assets/restaurant-hero.png"
                                    Stretch="UniformToFill" />
                    </Border.Background>
                    <Grid>
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#E6061714" Offset="0" />
                                    <GradientStop Color="#B4073D35" Offset="0.58" />
                                    <GradientStop Color="#30000000" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <StackPanel VerticalAlignment="Center"
                                    Margin="56"
                                    MaxWidth="520">
                            <Border Background="#33B7791F"
                                    CornerRadius="8"
                                    Padding="14,7"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,26">
                                <TextBlock Text="Dollar Restaurant"
                                           Foreground="#FDECC8"
                                           FontSize="13"
                                           FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Text="Dollar Restaurant"
                                       Foreground="White"
                                       FontSize="42"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Mon an da dang, khong gian am cung, dat ban nhanh va quan ly nha hang trong mot ung dung desktop."
                                       Foreground="#D6E9E4"
                                       FontSize="18"
                                       TextWrapping="Wrap"
                                       LineHeight="28"
                                       Margin="0,18,30,0" />

                            <UniformGrid Columns="3"
                                         Margin="0,42,0,0">
                                <StackPanel>
                                    <TextBlock Text="Admin"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Control"
                                               Foreground="#BFDBFE"
                                               FontSize="13" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Staff"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Booking"
                                               Foreground="#BFDBFE"
                                               FontSize="13" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Guest"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="History"
                                               Foreground="#BFDBFE"
                                               FontSize="13" />
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="64,40,72,40">
                    <Border Background="{StaticResource SurfaceBrush}"
                            Padding="42"
                            MaxWidth="430"
                            CornerRadius="8"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="26"
                                              ShadowDepth="8"
                                              Opacity="0.14"
                                              Color="#3A2C24" />
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Welcome Back"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="30"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Please login to continue"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="14"
                                       Margin="0,7,0,32" />

                            <TextBlock Text="Username"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6" />
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,20" />

                            <TextBlock Text="Password"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6" />
                            <PasswordBox helpers:PasswordHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,18" />

                            <Border Background="#FFF0EC"
                                    BorderBrush="#F2B8A2"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12"
                                    Margin="0,0,0,18">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding ErrorMessage}"
                                           Foreground="#A33B18"
                                           TextWrapping="Wrap" />
                            </Border>

                            <Button Content="{Binding IsBusy, Converter={StaticResource LoginTextConverter}}"
                                    IsDefault="True"
                                    Command="{Binding LoginCommand}" />

                            <Border Height="1"
                                    Background="#ECE5DD"
                                    Margin="0,28,0,18" />
                            <TextBlock Text="Use your employee or guest account from the existing SQL Server database."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ShellViewModel}">
            <Grid Background="{StaticResource RestaurantBgBrush}">
                <Grid.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#EAF7F3" />
                        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
                    </Style>
                    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#FDECC8" />
                        <Setter Property="FontSize" Value="20" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Margin" Value="0,0,0,14" />
                    </Style>
                    <Style x:Key="FormLabelStyle" TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#A8CCC4" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="Margin" Value="0,10,0,2" />
                    </Style>
                </Grid.Resources>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="268" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Padding="22">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#061D1A" Offset="0" />
                            <GradientStop Color="#0A3E36" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top">
                            <Border Background="#2AB7791F"
                                    CornerRadius="8"
                                    Padding="12,6"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,16">
                                <TextBlock Text="Dollar Restaurant"
                                           Foreground="#FDECC8"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Text="Restaurant"
                                       Foreground="White"
                                       FontSize="28"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding WelcomeText}"
                                       Foreground="#BEDBD3"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,28" />
                        </StackPanel>

                        <Button DockPanel.Dock="Bottom"
                                Content="Logout"
                                Command="{Binding LogoutCommand}"
                                Style="{StaticResource SidebarButtonStyle}"
                                Background="#8A2F2B"
                                Margin="0,20,0,0" />

                        <ItemsControl ItemsSource="{Binding MenuItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}"
                                            Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SidebarButtonStyle}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>

                <Grid Grid.Column="1" Margin="28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="#102F2A"
                            BorderBrush="#2F6F63"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="24,18"
                            Margin="0,0,0,18">
                        <DockPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedMenuItem}"
                                           Foreground="#FDECC8"
                                           FontSize="28"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding WelcomeText}"
                                           Foreground="#B8DAD2"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <TextBlock Text="{Binding Message}"
                                       Foreground="#F4C46D"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"
                                       TextWrapping="Wrap"
                                       Margin="24,8,0,0" />
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Background="#EC0B332D"
                            BorderBrush="#275F54"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="22">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18"
                                              ShadowDepth="5"
                                              Opacity="0.08"
                                              Color="#334155" />
                        </Border.Effect>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid Visibility="{Binding SelectedMenuItem, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Dashboard}">
                                <StackPanel>
                                    <TextBlock Text="Admin Dashboard" Style="{StaticResource SectionTitleTextStyle}" />
                                    <UniformGrid Columns="5" Margin="0,0,0,18">
                                        <Border Style="{StaticResource DarkMetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Employees" Foreground="#B8DAD2" />
                                                <TextBlock Text="{Binding Employees.Count}" FontSize="34" FontWeight="SemiBold" Foreground="#FDECC8" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource DarkMetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Customers" Foreground="#B8DAD2" />
                                                <TextBlock Text="{Binding Guests.Count}" FontSize="34" FontWeight="SemiBold" Foreground="#FDECC8" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource DarkMetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Tables" Foreground="#B8DAD2" />
                                                <TextBlock Text="{Binding Tables.Count}" FontSize="34" FontWeight="SemiBold" Foreground="#FDECC8" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource DarkMetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Pending" Foreground="#B8DAD2" />
                                                <TextBlock Text="{Binding PendingBookings.Count}" FontSize="34" FontWeight="SemiBold" Foreground="#FDECC8" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource DarkMetricCardStyle}" Margin="0">
                                            <StackPanel>
                                                <TextBlock Text="Feedbacks" Foreground="#B8DAD2" />
                                                <TextBlock Text="{Binding Feedbacks.Count}" FontSize="34" FontWeight="SemiBold" Foreground="#FDECC8" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.25*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Background="#F8FAFC" CornerRadius="8" Padding="16" Margin="0,0,14,0">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,10">
                                                    <TextBlock Text="Pending bookings" Foreground="#111827" FontSize="17" FontWeight="SemiBold" />
                                                    <Button DockPanel.Dock="Right" Content="Open" Command="{Binding NavigateCommand}" CommandParameter="Bookings" Width="80" Height="34" Background="{StaticResource RestaurantGoldBrush}" />
                                                </DockPanel>
                                                <DataGrid ItemsSource="{Binding PendingBookings}" SelectedItem="{Binding SelectedAppointment}" AutoGenerateColumns="False" IsReadOnly="True" Height="300">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Guest" Binding="{Binding Guest.Name}" Width="*" />
                                                        <DataGridTextColumn Header="Table" Binding="{Binding Table.TableName}" Width="*" />
                                                        <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="100" />
                                                        <DataGridTextColumn Header="Time" Binding="{Binding StartTime}" Width="90" />
                                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                    <Button Content="Confirm" Command="{Binding ConfirmBookingCommand}" Width="110" Margin="0,0,8,0" />
                                                    <Button Content="Cancel" Command="{Binding CancelBookingCommand}" Style="{StaticResource DangerButtonStyle}" Width="110" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="8" Padding="16">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,10">
                                                    <TextBlock Text="Table status" Foreground="#111827" FontSize="17" FontWeight="SemiBold" />
                                                    <Button DockPanel.Dock="Right" Content="Refresh" Command="{Binding RefreshTableStatusCommand}" Style="{StaticResource SecondaryButtonStyle}" Width="92" Height="34" />
                                                </DockPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <DatePicker SelectedDate="{Binding SelectedDate}" Width="145" />
                                                    <TextBox Text="{Binding StartTimeText}" Width="88" Margin="8,4,0,0" />
                                                    <TextBox Text="{Binding EndTimeText}" Width="88" Margin="8,4,0,0" />
                                                </StackPanel>
                                                <DataGrid ItemsSource="{Binding TableStatuses}" AutoGenerateColumns="False" IsReadOnly="True" Height="300">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Table" Binding="{Binding TableName}" Width="*" />
                                                        <DataGridCheckBoxColumn Header="Booked" Binding="{Binding IsBooked}" Width="80" />
                                                        <DataGridTextColumn Header="Guest" Binding="{Binding GuestName}" Width="*" />
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                            <Grid Visibility="{Binding SelectedMenuItem, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Employees}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="340" />
                                </Grid.ColumnDefinitions>
                                <DataGrid ItemsSource="{Binding Employees}"
                                          SelectedItem="{Binding SelectedEmployee}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding EmployeeId}" Width="60" />
                                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*" />
                                        <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="*" />
                                        <DataGridTextColumn Header="Role" Binding="{Binding RoleId}" Width="80" />
                                        <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="80" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Column="1" Style="{StaticResource FormPanelStyle}">
                                    <TextBlock Text="Employee Form" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="Username" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding EmployeeUsername, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Password" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding EmployeePassword, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Identity" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding EmployeeIdentityNumber, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Phone" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding EmployeePhoneNumber, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Date of Birth" Style="{StaticResource FormLabelStyle}" />
                                    <DatePicker SelectedDate="{Binding EmployeeDateOfBirth}" />
                                    <TextBlock Text="Gender" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding EmployeeGender, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Role ID" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding EmployeeRoleId, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Content="Active" IsChecked="{Binding EmployeeIsActive}" Margin="0,12,0,12" />
                                    <Button Content="Save" Command="{Binding SaveEmployeeCommand}" Margin="0,0,0,8" />
                                    <Button Content="New" Command="{Binding NewEmployeeCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8" />
                                    <Button Content="Delete" Command="{Binding DeleteEmployeeCommand}" Style="{StaticResource DangerButtonStyle}" />
                                </StackPanel>
                            </Grid>

                            <Grid Visibility="{Binding SelectedMenuItem, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Customers}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="340" />
                                </Grid.ColumnDefinitions>
                                <DataGrid ItemsSource="{Binding Guests}"
                                          SelectedItem="{Binding SelectedGuest}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding GuestId}" Width="60" />
                                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*" />
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="*" />
                                        <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="80" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Column="1" Style="{StaticResource FormPanelStyle}">
                                    <TextBlock Text="Customer Form" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="Username" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding GuestUsername, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Password" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding GuestPassword, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Name" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding GuestName, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Phone" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding GuestPhoneNumber, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Identity" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding GuestIdentityNumber, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Date of Birth" Style="{StaticResource FormLabelStyle}" />
                                    <DatePicker SelectedDate="{Binding GuestDateOfBirth}" />
                                    <TextBlock Text="Gender" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding GuestGender, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Content="Save" Command="{Binding SaveGuestCommand}" Margin="0,16,0,8" />
                                    <Button Content="New" Command="{Binding NewGuestCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8" />
                                    <Button Content="Block / Active" Command="{Binding ToggleGuestStatusCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8" />
                                    <Button Content="Reset Password" Command="{Binding ResetGuestPasswordCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8" />
                                    <Button Content="Delete" Command="{Binding DeleteGuestCommand}" Style="{StaticResource DangerButtonStyle}" />
                                </StackPanel>
                            </Grid>

                            <Grid Visibility="{Binding SelectedMenuItem, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Tables}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="320" />
                                </Grid.ColumnDefinitions>
                                <DataGrid ItemsSource="{Binding Tables}" SelectedItem="{Binding SelectedTable}" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding TableId}" Width="80" />
                                        <DataGridTextColumn Header="Table Name" Binding="{Binding TableName}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Column="1" Style="{StaticResource FormPanelStyle}">
                                    <TextBlock Text="Table Form" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="Table Name" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding TableName, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Content="Save" Command="{Binding SaveTableCommand}" Margin="0,16,0,8" />
                                    <Button Content="New" Command="{Binding NewTableCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8" />
                                    <Button Content="Delete" Command="{Binding DeleteTableCommand}" Style="{StaticResource DangerButtonStyle}" />
                                </StackPanel>
                            </Grid>

                            <Grid Visibility="{Binding SelectedMenuItem, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Bookings}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="340" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Booking queue" Style="{StaticResource SectionTitleTextStyle}" />
                                        <DataGrid ItemsSource="{Binding Appointments}" SelectedItem="{Binding SelectedAppointment}" AutoGenerateColumns="False" IsReadOnly="True" Height="470">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Guest" Binding="{Binding Guest.Name}" Width="*" />
                                                <DataGridTextColumn Header="Table" Binding="{Binding Table.TableName}" Width="*" />
                                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="110" />
                                                <DataGridTextColumn Header="Start" Binding="{Binding StartTime}" Width="90" />
                                                <DataGridTextColumn Header="End" Binding="{Binding EndTime}" Width="90" />
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="105" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Background="#F8FAFC"
                                            CornerRadius="8"
                                            Padding="18"
                                            Margin="18,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Booking Detail" Foreground="#111827" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14" />
                                            <TextBlock Text="Guest" Style="{StaticResource FormLabelStyle}" />
                                            <TextBlock Text="{Binding SelectedAppointment.Guest.Name}" Foreground="#111827" FontWeight="SemiBold" />
                                            <TextBlock Text="Table" Style="{StaticResource FormLabelStyle}" />
                                            <TextBlock Text="{Binding SelectedAppointment.Table.TableName}" Foreground="#111827" FontWeight="SemiBold" />
                                            <TextBlock Text="Date" Style="{StaticResource FormLabelStyle}" />
                                            <TextBlock Text="{Binding SelectedAppointment.Date, StringFormat=d}" Foreground="#111827" FontWeight="SemiBold" />
                                            <TextBlock Text="Time" Style="{StaticResource FormLabelStyle}" />
                                            <TextBlock Foreground="#111827" FontWeight="SemiBold">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} - {1}">
                                                        <Binding Path="SelectedAppointment.StartTime" />
                                                        <Binding Path="SelectedAppointment.EndTime" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock Text="Status" Style="{StaticResource FormLabelStyle}" />
                                            <TextBlock Text="{Binding SelectedAppointment.Status}" Foreground="#B7791F" FontWeight="SemiBold" FontSize="18" />
                                            <Border Height="1" Background="#E2E8F0" Margin="0,16,0,16" />
                                            <Button Content="Confirm booking" Command="{Binding ConfirmBookingCommand}" Margin="0,0,0,8" />
                                            <Button Content="Mark completed" Command="{Binding CompleteBookingCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8" />
                                            <Button Content="Cancel booking" Command="{Binding CancelBookingCommand}" Style="{StaticResource DangerButtonStyle}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>

                            <Grid Visibility="{Binding SelectedMenuItem, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Feedbacks}">
                                <DataGrid ItemsSource="{Binding Feedbacks}" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Guest" Binding="{Binding Guest.Name}" Width="*" />
                                        <DataGridTextColumn Header="Table" Binding="{Binding Appointment.Table.TableName}" Width="*" />
                                        <DataGridTextColumn Header="Rating" Binding="{Binding Rating}" Width="80" />
                                        <DataGridTextColumn Header="Content" Binding="{Binding Content}" Width="2*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>

                            <Grid Visibility="{Binding SelectedMenuItem, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Staff Booking}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="320" />
                                </Grid.ColumnDefinitions>
                                <DataGrid ItemsSource="{Binding TableStatuses}" SelectedValue="{Binding BookingTableId}" SelectedValuePath="TableId" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding TableId}" Width="60" />
                                        <DataGridTextColumn Header="Table" Binding="{Binding TableName}" Width="*" />
                                        <DataGridCheckBoxColumn Header="Booked" Binding="{Binding IsBooked}" Width="90" />
                                        <DataGridTextColumn Header="Guest" Binding="{Binding GuestName}" Width="*" />
                                        <DataGridTextColumn Header="Time" Binding="{Binding TimeRange}" Width="150" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Column="1" Style="{StaticResource FormPanelStyle}">
                                    <TextBlock Text="Booking Form" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="Date" Style="{StaticResource FormLabelStyle}" />
                                    <DatePicker SelectedDate="{Binding SelectedDate}" />
                                    <TextBlock Text="Start / End" Style="{StaticResource FormLabelStyle}" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox Text="{Binding StartTimeText}" Width="110" />
                                        <TextBox Text="{Binding EndTimeText}" Width="110" Margin="8,0,0,0" />
                                    </StackPanel>
                                    <Button Content="Refresh Tables" Command="{Binding RefreshTableStatusCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,12,0,18" />
                                    <TextBlock Text="Walk-in Guest" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding WalkInGuestName, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,8" />
                                    <TextBox Text="{Binding WalkInGuestPhone, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Content="Book Selected Table" Command="{Binding CreateWalkInBookingCommand}" Margin="0,14,0,0" />
                                </StackPanel>
                            </Grid>

                            <Grid Visibility="{Binding SelectedMenuItem, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Table Status}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <DatePicker SelectedDate="{Binding SelectedDate}" Width="160" />
                                        <TextBox Text="{Binding StartTimeText}" Width="110" Margin="8,0,0,0" />
                                        <TextBox Text="{Binding EndTimeText}" Width="110" Margin="8,0,0,0" />
                                        <Button Content="Refresh" Command="{Binding RefreshTableStatusCommand}" Style="{StaticResource SecondaryButtonStyle}" Width="120" Margin="8,0,0,0" />
                                    </StackPanel>
                                    <DataGrid ItemsSource="{Binding TableStatuses}" AutoGenerateColumns="False" IsReadOnly="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Table" Binding="{Binding TableName}" Width="*" />
                                            <DataGridCheckBoxColumn Header="Booked" Binding="{Binding IsBooked}" Width="100" />
                                            <DataGridTextColumn Header="Guest" Binding="{Binding GuestName}" Width="*" />
                                            <DataGridTextColumn Header="Time" Binding="{Binding TimeRange}" Width="160" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Grid>

                            <Grid Visibility="{Binding SelectedMenuItem, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Menu}">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,18">
                                        <StackPanel>
                                            <TextBlock Text="Choose dishes first"
                                                       Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Text="Select the dishes you want. After that, continue to choose table, date, and time."
                                                       Foreground="#B8DAD2"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Border DockPanel.Dock="Right"
                                                Background="#123F37"
                                                BorderBrush="#4D8577"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="14,10"
                                                Width="330">
                                            <StackPanel>
                                                <TextBlock Text="Selected dishes"
                                                           Foreground="#FDECC8"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding SelectedDishesText}"
                                                           Foreground="#B8DAD2"
                                                           TextWrapping="Wrap"
                                                           Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </DockPanel>

                                    <ItemsControl ItemsSource="{Binding Dishes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="5" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource FoodCardStyle}" MinHeight="190">
                                                    <StackPanel>
                                                        <Border Height="76"
                                                                CornerRadius="6"
                                                                ClipToBounds="True"
                                                                Margin="0,0,0,12">
                                                            <Border.Background>
                                                                <ImageBrush ImageSource="Assets/restaurant-hero.png"
                                                                            Stretch="UniformToFill"
                                                                            Viewbox="0.28,0.40,0.44,0.40" />
                                                            </Border.Background>
                                                        </Border>
                                                        <TextBlock Text="{Binding Category}"
                                                                   Foreground="#F4C46D"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,4,0,0" />
                                                        <TextBlock Text="{Binding Description}"
                                                                   Foreground="#B8DAD2"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"
                                                                   Height="42"
                                                                   Margin="0,6,0,0" />
                                                        <DockPanel Margin="0,10,0,0">
                                                            <TextBlock Text="{Binding PriceText}"
                                                                       Foreground="#FDECC8"
                                                                       FontWeight="SemiBold"
                                                                       VerticalAlignment="Center" />
                                                            <CheckBox DockPanel.Dock="Right"
                                                                      Content="Choose"
                                                                      Foreground="#EAF7F3"
                                                                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      HorizontalAlignment="Right" />
                                                        </DockPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Button Content="Continue to booking"
                                            Command="{Binding ContinueToBookingCommand}"
                                            Background="{StaticResource RestaurantGoldBrush}"
                                            Width="190"
                                            HorizontalAlignment="Right"
                                            Margin="0,20,0,0" />
                                </StackPanel>
                            </Grid>

                            <Grid Visibility="{Binding SelectedMenuItem, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Customer Booking}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="300" />
                                </Grid.ColumnDefinitions>
                                <DataGrid ItemsSource="{Binding TableStatuses}" SelectedValue="{Binding BookingTableId}" SelectedValuePath="TableId" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Table" Binding="{Binding TableName}" Width="*" />
                                        <DataGridCheckBoxColumn Header="Booked" Binding="{Binding IsBooked}" Width="100" />
                                        <DataGridTextColumn Header="Guest" Binding="{Binding GuestName}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Column="1" Style="{StaticResource FormPanelStyle}">
                                    <TextBlock Text="Booking Form" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="Selected dishes" Style="{StaticResource FormLabelStyle}" />
                                    <TextBlock Text="{Binding SelectedDishesText}"
                                               Foreground="#B8DAD2"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Date" Style="{StaticResource FormLabelStyle}" />
                                    <DatePicker SelectedDate="{Binding SelectedDate}" />
                                    <TextBlock Text="Start / End" Style="{StaticResource FormLabelStyle}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <TextBox Text="{Binding StartTimeText}" Width="110" />
                                        <TextBox Text="{Binding EndTimeText}" Width="110" Margin="8,0,0,0" />
                                    </StackPanel>
                                    <Button Content="Find Tables" Command="{Binding RefreshTableStatusCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,12,0,8" />
                                    <Button Content="Book Selected Table" Command="{Binding CreateCustomerBookingCommand}" />
                                </StackPanel>
                            </Grid>

                            <Grid Visibility="{Binding SelectedMenuItem, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Booking History}">
                                <StackPanel>
                                    <DataGrid ItemsSource="{Binding BookingHistory}" SelectedItem="{Binding SelectedHistory}" AutoGenerateColumns="False" IsReadOnly="True" Height="420">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Table" Binding="{Binding Table.TableName}" Width="*" />
                                            <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="120" />
                                            <DataGridTextColumn Header="Start" Binding="{Binding StartTime}" Width="100" />
                                            <DataGridTextColumn Header="End" Binding="{Binding EndTime}" Width="100" />
                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <Button Content="Cancel Selected Booking" Command="{Binding CancelHistoryBookingCommand}" Style="{StaticResource DangerButtonStyle}" Width="190" Margin="0,14,0,0" />
                                </StackPanel>
                            </Grid>

                            <Grid Visibility="{Binding SelectedMenuItem, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Feedback}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="320" />
                                </Grid.ColumnDefinitions>
                                <DataGrid ItemsSource="{Binding BookingHistory}" SelectedItem="{Binding SelectedHistory}" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Table" Binding="{Binding Table.TableName}" Width="*" />
                                        <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="120" />
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Column="1" Style="{StaticResource FormPanelStyle}">
                                    <TextBlock Text="Feedback Form" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="Rating 1-5" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding FeedbackRating, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Content" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding FeedbackContent, UpdateSourceTrigger=PropertyChanged}" Height="120" TextWrapping="Wrap" AcceptsReturn="True" />
                                    <Button Content="Submit Feedback" Command="{Binding SubmitFeedbackCommand}" Margin="0,14,0,0" />
                                </StackPanel>
                            </Grid>

                            <Grid Visibility="{Binding SelectedMenuItem, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Profile}">
                                <StackPanel Width="420" HorizontalAlignment="Left">
                                    <TextBlock Text="Profile Form" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="Name" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding GuestName, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Identity" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding GuestIdentityNumber, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Phone" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding GuestPhoneNumber, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Date of Birth" Style="{StaticResource FormLabelStyle}" />
                                    <DatePicker SelectedDate="{Binding GuestDateOfBirth}" />
                                    <TextBlock Text="Gender" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding GuestGender, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Content="Save Profile" Command="{Binding SaveProfileCommand}" Margin="0,16,0,0" />
                                </StackPanel>
                            </Grid>

                            <Grid Visibility="{Binding SelectedMenuItem, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Change Password}">
                                <StackPanel Width="420" HorizontalAlignment="Left">
                                    <TextBlock Text="Password Form" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="Old Password" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding OldPassword, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="New Password" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Content="Change Password" Command="{Binding ChangePasswordCommand}" Margin="0,16,0,0" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <ContentControl Content="{Binding CurrentViewModel}" />
</Window>
