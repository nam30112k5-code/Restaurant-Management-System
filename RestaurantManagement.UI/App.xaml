<Application x:Class="RestaurantManagement.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#B95C2D" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#6F3F2A" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2E7D6B" />
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F4F1EC" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FAF7F2" />
        <SolidColorBrush x:Key="TextBrush" Color="#222222" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6F6A63" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DDD5CC" />
        <SolidColorBrush x:Key="GridHeaderBrush" Color="#EFE7DE" />
        <SolidColorBrush x:Key="GridRowHoverBrush" Color="#F8EEE5" />

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#FFFCF8" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#FFFCF8" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="#FFFCF8" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="46" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EEE6DE" />
            <Setter Property="RowHeight" Value="40" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="AlternatingRowBackground" Value="#FFFCF8" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource GridHeaderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Application.Resources>
</Application>
